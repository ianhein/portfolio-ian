---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Project from "../components/Project.astro";

const projects = [
  {
    title: "Lácteos Tonutti - Industrial System",
    desc: [
      "Developed a comprehensive industrial management system",
      "Built backend logic using PHP and Python",
      "Implemented PostgreSQL database for reliable data storage",
    ],
    tech: ["PHP", "Python", "PostgreSQL"],
  },
  {
    title: "Lácteos Tonutti - Landing Page",
    desc: [
      "Designed and developed the new corporate landing page",
      "Focus on high performance and SEO optimization",
    ],
    tech: ["Astro", "HTML", "CSS"],
  },
  {
    title: "ATC Flight School",
    desc: [
      "Full-stack web application for an aviation school",
      "Modern UI built with React and Tailwind CSS",
      "Robust backend with Node.js, Express, and TypeScript",
    ],
    tech: ["React", "Node.js", "Express.js", "TypeScript", "Tailwind"],
  },
];
---

<!doctype html>
<html>
  <Header title="Ian" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1>Hi, I'm Ian.<br />I'm an experienced frontend developer.</h1>
              <p class="lead">
                I transform designs into interactive, pixel-perfect web
                experiences. Passionate about micro-interactions, responsive
                design, and visual detail.
              </p>
            </div>
            <a href="mailto:ianhein50@gmail.com" class="button w-button"
              >Contact</a
            >
          </main>
          <div class="projects-section">
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </nav>
    </div>
    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
