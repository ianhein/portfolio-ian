---
import Header from "../../components/Header.astro";
import Project from "../../components/Project.astro";
import Sidebar from "../../components/Sidebar.astro";
import { projectData } from "../../i18n/data";
import { ui } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "pt" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);
const projects = projectData[lang as keyof typeof ui].personalProjects;
---

<!doctype html>
<html>
  <Header title="Personal Projects | Ian" />
  <body>
    <div class="content">
      <Sidebar selectedItem="personal-projects" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a
              href={`/${lang === "en" ? "" : lang}`}
              class="back-nav-button w-inline-block"
              ><img
                src="/assets/back.svg"
                loading="eager"
                alt=""
                class="back-nav-img"
              />
              <div>{t("back.button")}</div></a
            >
          </div>
          <div class="content-container">
            <h1>{t("personal-projects.title")}</h1>
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                      url={project.url}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
