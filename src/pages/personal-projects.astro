---
import Header from "../components/Header.astro";
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
const projects = [
  {
    title:
      "<a href='https://kahoovie.vercel.app/' target='_blank' class='project-link'>Kahoovie</a>",
    desc: ["A Kahoot-like game focused exclusively on movies."],
    tech: ["React", "Node.js", "Tailwind"],
  },
  {
    title:
      "<a href='https://manager-choripaneada.vercel.app/' target='_blank' class='project-link'>Choripaneada CRM</a>",
    desc: [
      "Custom CRM built for a university event ('Choripaneada') for Systems Engineering students.",
      "Managed user accounts, orders, and payments.",
      "Generated QR codes for attendees to claim their food orders.",
    ],
    tech: ["React", "Node.js", "PostgreSQL"],
  },
  {
    title: "Stroke Rehab App",
    desc: [
      "Android application designed to assist post-stroke patients in their rehabilitation process.",
      "Currently in development.",
    ],
    tech: ["Android"],
  },
];
---

<!doctype html>
<html>
  <Header title="Personal Projects | Ian" />
  <body>
    <div class="content">
      <Sidebar selectedItem="personal-projects" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img
                src="/assets/back.svg"
                loading="eager"
                alt=""
                class="back-nav-img"
              />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>Personal Projects</h1>
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
